      <body>
         <div type="edition" subtype="primary" xml:space="preserve" xml:lang="grc" resp="#JP"><!-- needs proofreading still -->
            <div type="textpart" subtype="column" n="1">
               <ab>
               <cb n="1"/>
                 <lb n="1"/><gap reason="lost" unit="character" quantity="8"/><gap reason="illegible" unit="character" quantity="1"/><orig>ΑΝ</orig><gap reason="lost" unit="character" quantity="4"/><orig><unclear>Α</unclear></orig><gap reason="lost" unit="character" extent="unknown"/>
                  <lb n="2"/><gap reason="lost" unit="character" quantity="6"/><gap reason="illegible" unit="character" quantity="1"/><orig>ΔΕΜΑ</orig><gap reason="lost" unit="character" quantity="1"/><unclear>Α</unclear><gap reason="lost" unit="character" quantity="1"/><orig>ΤΕ Η<unclear>ΑΛ</unclear>ΑΤ<unclear>Ε</unclear>ΡΑ</orig><gap reason="lost" unit="character" quantity="1"/><orig>ΚΑ<unclear>ΙΟ</unclear></orig><gap reason="lost" unit="character" extent="unknown"/>
                  <lb n="3"/><gap reason="lost" unit="character" quantity="4" cert="low"/><gap reason="illegible" unit="character" quantity="1"/><unclear>Β</unclear><gap reason="lost" unit="character" quantity="1"/> καταλ<supplied reason="lost">ε</supplied><unclear>ί</unclear>ποντας κα<unclear>τ</unclear>ͱαιγίζ<unclear>ε</unclear>ν δὲ τὸς ͱομοσεπύος <space unit="character" extent="unknown"/>
                  <lb n="4"/><del rend="erasure"><gap reason="lost" unit="character" extent="unknown"/></del>
                  <lb n="5"/><del rend="erasure"><gap reason="lost" unit="character" extent="unknown"/></del>
                  <lb n="6"/><del rend="erasure"><gap reason="lost" unit="character" extent="unknown"/></del>
                  <lb n="7"/>το͂ν ͱιαρο͂ν ͱα θυσία πρὸ Ϙοτυτίον καὶ τᾶς ἐχεχερίας πέν<unclear>π</unclear><supplied reason="lost">τοι</supplied>
                  <lb n="8"/> ϝέτει ͱο͂ιπερ ͱόκα ͱα Ὀλυνπιὰς ποτείε· το͂ι Διὶ <g ref="#dipunct">⁚</g> το͂ι Εὐμενεῖ θύ<supplied reason="lost">ε</supplied><unclear>ν</unclear> <supplied reason="lost">καὶ</supplied>
                  <lb n="9"/> ταῖς  <g ref="#dipunct">⁚</g> Εὐμενίδεσι <g ref="#dipunct">⁚</g> τέλεον, καὶ το͂ι Διὶ  <g ref="#dipunct">⁚</g> το͂ι Μιλιχίοι το͂ι  <g ref="#dipunct">⁚</g> ἐν Μύσϙο <g ref="#dipunct">⁚</g> τέλεον <g ref="#dipunct">⁚</g> τοῖς Τρ
                  <lb n="10" break="no"/>ιτοπατρεῦσι <g ref="#interpunct">·</g> τοῖς <g ref="#interpunct">·</g> μιαροῖς ͱόσπερ τοῖς ͱερόεσι, ϝοῖνον ͱυπολͱεί
                  <lb n="11" break="no"/>ψας <g ref="#interpunct">·</g> δι’ ὀρόφο <g ref="#interpunct">·</g> καὶ τᾶν μοιρᾶν τᾶν ἐνάταν <g ref="#interpunct">·</g> κατακα
                  <lb n="12" break="no"/>ίεν <g ref="#interpunct">·</g> μίαν. θυόντο θῦμα <g ref="#dipunct">⁚</g> καὶ καταγιζόντο ͱοῖς ͱοσία <g ref="#interpunct">·</g> καὶ περιρά
                  <lb n="13" break="no"/>ναντες καταλινάντο <g ref="#dipunct">⁚</g> κἔπειτα <g ref="#dipunct">⁚</g> τοῖς κ<supplied reason="omitted">α</supplied>θαροῖς <g ref="#dipunct">⁚</g> τέλεον θυόντο̄ <g ref="#dipunct">⁚</g> μελίκρατα ͱυπο
                  <lb n="14"/>λείβον <g ref="#interpunct">·</g> καὶ τράπεζαν καὶ κλίναν κἐνβαλέτο καθαρὸν ͱε͂μα καὶ στεφά
                  <lb n="15" break="no"/>νος ἐλαίας καὶ μελίκρατα ἐν καιναῖς ποτε̄ρίδ<unclear>ε</unclear><supplied reason="lost">σ</supplied>ι καὶ <g ref="#dipunct">⁚</g> πλάσματα καὶ κρᾶ κἀπ
                  <lb n="16" break="no"/>αρξάμενοι κατακαάντο καὶ καταλινάντο <unclear>τ</unclear>ὰς ποτε̄ρίδας ἐνθέντε<unclear>ς</unclear>.
                  <lb n="17"/>θυόν<unclear>τ</unclear>ο̄ ͱό̄σπερ τοῖς θεοῖς τὰ πατρο͂ια <g ref="#dipunct">⁚</g> το͂ι ἐν Εὐθυδάμο̄ Μιλιχίο̄ι <g ref="#dipunct">⁚</g> κριὸν <unclear>θ</unclear><supplied reason="lost">υ</supplied>
                  <lb n="18" break="no"/>όντο̄. ἔστο̄ δὲ καὶ θῦμα πεδὰ ϝέτος θύε̄ν. τὰ δὲ ͱιαρὰ τὰ δαμόσια ἐξͱ<supplied reason="omitted">α</supplied>ιρέτο̄ καὶ τρά<supplied reason="lost">πεζα</supplied>
                  <lb n="19" break="no"/>ν <g ref="#dipunct">⁚</g> προθέμεν καὶ ϙολέαν καὶ τἀπὸ τᾶς τραπέζας <g ref="#dipunct">⁚</g> ἀπάργματα καὶ τὀστέα κα<supplied reason="lost">τα</supplied>
                  <lb n="20" break="no"/>κᾶαι <g ref="#interpunct">·</g> τὰ κρᾶ μἐχφερέτο̄. καλέ̄το̄ <supplied reason="lost">ͱ</supplied>όντινα λε͂ι. ἔστο̄ δὲ καὶ πεδὰ ϝέτ<supplied reason="lost">ος</supplied> <supplied reason="lost">ϝ</supplied>
                  <lb n="21" break="no"/>οίϙοι θύεν <g ref="#dipunct">⁚</g> σφαζόντο δὲ <g ref="#dipunct">⁚</g> καὶ β<supplied reason="lost">ν</supplied> <supplied reason="lost">πρ</supplied>ὸ ἀγαλμάτο̄ν <gap reason="lost" unit="character" quantity="3"/><orig><unclear>Δ</unclear>ΕΣ</orig><gap reason="lost" unit="character" extent="unknown"/>
                  <lb n="22"/> Ο θῦμα ͱότι κα προχο̄ρε͂ι τὰ πατρο͂<supplied reason="lost">ια</supplied><gap reason="lost" unit="character" quantity="1"/><orig>ΕΞΑΙ</orig><gap reason="illegible" unit="character" quantity="1"/><gap reason="lost" unit="character" extent="unknown"/>
                  <lb n="23"/><orig><unclear>Τ</unclear></orig><gap reason="lost" unit="character" quantity="2"/><orig>ΙΤΟΙΑΠΤΟΧΟΙ</orig> τρίτοι ϝέ<unclear>τ</unclear><supplied reason="lost">ει</supplied> <orig><unclear>Ε</unclear></orig><gap reason="lost" unit="character" extent="unknown"/>
                  <lb n="24"/><gap reason="lost" unit="character" atLeast="7" atMost="8"/><orig><unclear>Ε</unclear>ΥΣΥΝ<unclear>Β</unclear></orig><gap reason="lost" unit="character" extent="unknown"/>
            </ab>
         </div>
            <div type="textpart" subtype="column" n="2">
               <ab>
                  <cb n="2"/>
                  <lb n="1"/><supplied reason="lost">αἴ</supplied> <unclear>κ</unclear>᾿ ἄ<unclear>ν</unclear>θρ<unclear>ο</unclear>̄<unclear>πο</unclear>ς <supplied reason="lost">αὐτορέκ</supplied>τ<supplied reason="lost">ας</supplied> <supplied reason="lost">ἐλ</supplied>αστέρο̄ν ἀποκα<supplied reason="lost">θαίρεσθαι</supplied>
                  <lb n="2"/><supplied reason="lost">λε͂ι</supplied>, προειπὸ̄ν hόπο̄ κα λε͂ι<unclear> κ</unclear>αὶ το͂ ϝ<unclear>έ</unclear><supplied reason="lost">τ</supplied><unclear>ε</unclear>ος hοπ〈εί〉ο̄ κα λε͂ι καὶ <supplied reason="lost">το͂ με̄νὸς</supplied>
                  <lb n="3"/>hοπείο̄ κα λε͂ι καὶ ἀμέραι hοπείαι κα λ<supplied reason="omitted">ε͂</supplied>ι, ποροειπὸ̄ν hὸπυι κα λε͂ι, καθαιρέσθο̄, <supplied reason="lost">Hο</supplied> <supplied reason="lost">hυ</supplied>
                  <lb n="4" break="no"/>ποδεκόμενος ἀπονίψασθαι δότο̄ κἀκρατίξασθαι καὶ hάλα το͂ι αὐ<supplied reason="lost">τορέκ</supplied>
                  <lb n="5" break="no"/><supplied reason="lost">τ</supplied>α θύσας το͂ι Δὶ χοῖρον ἐξ αὐτο͂ ἴτο καὶ περιστιραφέσθο̄
                  <lb n="6"/>καὶ ποταγορέ̄σθο̄ καὶ σῖτον hαιρέ̄σθο καὶ καθευδέτο̄ hοπε̄ <unclear>κ</unclear>
                  <lb n="7" break="no"/>α λε͂ι. αἴ τίς κα λε͂ι ξενικὸν ἒ πατρο͂ιον ἒ ᾿πακουστὸν ἒ ᾿φορατὸν
                  <lb n="8"/>ἒ καὶ χὄντινα καθαίρεσθαι, τὸν αὐτὸν τρόπο<unclear>ν</unclear> <unclear>κ</unclear>αθαιρέσθο̄
                  <lb n="9"/>hόνπερ hοὐτορέκτας ἐπεί κ᾿ἐλαστέρο̄ ἀποκαθάρε̄ται.
                  <lb n="10"/>hιαρεῖον τέλεον ἐπὶ το͂ι βομο͂ι το͂ι δαμασίο̄ι θύσας καθαρὸ
                  <lb n="11" break="no"/>ς ἔστο̄. διορίξας hαλὶ καὶ χρυσο͂ι ἀπορανάμενος ἀπίτο̄.
                  <lb n="12"/>hόκα το͂ι Ἐλαστέρο̄ι χρέ̄ζει θύε̄ν, θύε̄ν hό̄σπερ τοῖς
                  <lb n="13"/>ἀθανάτοισι. σφαζέτο̄ δ᾿ ἐς γᾶν.
               </ab>
