            <div type="edition" subtype="primary" xml:space="preserve" xml:lang="grc">
              <ab>
                    <lb n="1"/><w n="5">Ἄρχωνος</w> <w n="10">Νικὼ</w> <w lemma="νόμιμος" rend="νομίμη" n="15">νομίμη</w> <w lemma="δάμαρ" rend="δάμαρ" n="20">δάμαρ</w>· <w lemma="ἀλλά" rend="ἀλλὰ" n="25">ἀλλὰ</w> <w lemma="κομίζω" rend="κομίζει" n="30">κομίζει</w>
                    <lb n="2"/><w n="35">Ἅιδης,</w> <w lemma="οὐ" rend="οὐ" n="40">οὐ</w> <w lemma="κακία" rend="κακίην" n="45">κακίην</w> <w lemma="οὐδέ" rend="οὐδ" n="50">οὐδ</w> <w n="55">̓</w> <w lemma="ἀρετή" rend="ἀρετὴν" n="60">ἀρετὴν</w> <w lemma="ἐτάζω" rend="ἐτάσας" n="65">ἐτάσας</w>·
                    <lb n="3"/><w lemma="ὁ" rend="τὴν" n="70">τὴν</w> <w lemma="πινυτός" rend="πινυτὴν" n="75">πινυτὴν</w> <w lemma="δέ" rend="δ " n="80">δ</w> <w n="85">̓</w> <w lemma="αὐτός" rend="αὐτὸς" n="90">αὐτὸς</w> <w lemma="καί" rend="καὶ" n="95">καὶ</w> <w lemma="ἀμέμφης" rend="ἀμεμφέα" n="100">ἀμεμφέα</w> <w lemma="τῆδε" rend="τεῖδε" n="105">τεῖδε</w> <w lemma="θνῄσκω" rend="θανοῦσαν" n="110">θανοῦσαν</w>
