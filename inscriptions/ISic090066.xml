                    <lb n="5"/><w n="140">Κρῆσσαν</w> <w n="145">Ἀριστοκράτους</w> <w lemma="κόρη" rend="κούρην" n="150">κούρην</w>· <w lemma="ὁ" rend="τὸ" n="155">τὸ</w> <w lemma="δέ" rend="δὲ" n="160">δὲ</w> <w lemma="διπλόος" rend="διπλόον" n="165">διπλόον</w> <w lemma="ἄλγος" rend="ἄλγος" n="170">ἄλγος</w>,
                    <lb n="6"/><w lemma="πρίν" rend="πρὶν" n="175">πρὶν</w> <w lemma="τέκνον" rend="τέκνα" n="180">τέκνα</w> <w lemma="ὁ" rend="τὴν" n="185">τὴν</w> <w lemma="ὅσιος" rend="ὁσίην" n="190">ὁσίην</w> <w lemma="ἐσθλός" rend="ἐσθλὰ" n="195">ἐσθλὰ</w> <w lemma="γυνή" rend="γυναῖκα" n="200">γυναῖκα</w> <w lemma="τίκτω" rend="τεκεῖν" n="205">τεκεῖν</w>.
                    <lb n="7"/><w lemma="ἀλλά" rend="ἀλλ" n="210">ἀλλ</w> <w n="215">̓</w> <w lemma="ἐπί" rend="ἐπὶ" n="220">ἐπὶ</w> <w lemma="λωΐων" rend="λώιονι" n="225">λώιονι</w> <w lemma="μέν" rend="μὲν" n="230">μὲν</w> <w lemma="μοῖρα" rend="μοίρηι" n="235">μοίρηι</w> <w lemma="νύμφη" rend="νύμφην" n="240">νύμφην</w> <w lemma="τις" rend="τις" n="245">τις</w> <w lemma="ἄγω" rend="ἄγοιτο" n="250">ἄγοιτο</w>,
