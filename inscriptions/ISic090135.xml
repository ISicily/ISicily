                <ab>
                    <lb n="1"/><w lemma="ἥρως" rend="Ἥρωι" n="5">Ἥρωι</w> <w lemma="μέγας" rend="μεγάλωι" n="10">μεγάλωι</w> <w lemma="καί" rend="καὶ" n="15">καὶ</w> <w lemma="ὁ" rend="τοῖς" n="20">τοῖς</w>
