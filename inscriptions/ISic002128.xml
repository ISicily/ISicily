            <div type="edition" subtype="primary" xml:space="preserve" xml:lang="grc" resp="#JP">
                <ab>
                    <lb n="1"/>ΑΝΑΘΗ<gap reason="lost" extent="unknown" unit="character"/>Ι ΙΙΙ<gap reason="illegible" unit="character" quantity="1"/><gap reason="lost" unit="character" quantity="20" precision="medium"/>ΣΜΑ
                    <lb n="2"/>ΞΙΜΟΥΘΕΟΔΩΡΟΣ<gap reason="lost" unit="character" quantity="14" precision="medium"/><gap reason="illegible" unit="character" quantity="2"/>
                    <lb n="3"/>ΤΟΝΚΡΑΤΗΡΑ<gap reason="lost" unit="character" quantity="14" precision="medium"/>ΡΟΝ
                </ab>
            </div>
            <div type="apparatus">
