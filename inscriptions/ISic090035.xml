                        <rdg>Πτολε[μαῖον Πτολεμαίου καὶ] | Βερενίκη[ς θεῶν Εὐεργετῶν] <note>Breccia</note></rdg>
                    </app>
                    <app loc="2">
                        <rdg>Βερενίκη̣[ν - - -] <note>Botti 1897</note></rdg> 
                        <rdg>Βερενίκη̣[ν βασιλίσσαν] <note>Botti 1898</note></rdg>
                    </app>
