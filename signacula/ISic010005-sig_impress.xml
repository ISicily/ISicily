                    <physDesc>
                        <objectDesc>
                            <supportDesc>
                                <support><p>plastered front of an arcosolium</p>
                                <objectType ana="#object.funerary_monument.tomb" ref="https://www.eagle-network.eu/voc/objtyp/lod/447.html">arcosolium</objectType>
                                    <material ana="#material.plaster">plaster</material>
                                    <dimensions>
                                        <height unit="cm"></height>
                                        <width unit="cm"></width>
                                        <depth unit="cm"></depth>
                                        <dim type="diameter" unit="cm"></dim>
                                      </dimensions>
                                    <measure type="weight" unit="gr"/>
                                </support>
                                <condition ana="#condition.damaged"/>
                            </supportDesc>
                            <layoutDesc>
                                <layout>
                                    <p>4 impressions of the same circular <rs ana="#signaculum.circular">signaculum</rs> impressed on the four corners of a rectangular tabula etched in fresco 
                                    on the plaster covering the forehead of a trisome arcosolium and preserving the inscription of the deceased (see <ref target=
                                        "http://sicily.classics.ox.ac.uk/inscription/ISic000889">ISic000889</ref>). Three impressions have gaps due to the fall of the plaster, 
                                    the fourth, on the upper right corner of the tabula is complete. Epigraphic field divided into two concentric registers delimited by a linear frame. Other impressions of the same signaculum have been found along the corridor,
                                    on fragments of mortar that probably belong to the cover of, at least, one of the tombs located within the arcosolium (<ref target="http://sicily.classics.ox.ac.uk/inscription/ISic010006">ISic010006</ref>).</p>
                                    <dimensions unit="mm"><dim type="diameter">80</dim></dimensions>
                                    <rs ana="#execution.stamped" ref="https://ontology.inscriptiones.org/execution_technique/Stamp">impressed</rs>
                                    <damage ana="#text_condition.complete #text_condition.legible"/>                         
                                </layout>
                            </layoutDesc>
                        </objectDesc>
                        <handDesc>
                            <handNote>
                                <p>A with broken crossbar.</p>
                                <locus from="line1" to="line2">Line 1-2</locus>
                                <dimensions type="letterHeight"><height unit="mm"/><height>15</height></dimensions>
                           </handNote>
                        </handDesc>
